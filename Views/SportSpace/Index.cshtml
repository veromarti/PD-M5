@model IEnumerable<SportComplex.Models.SportSpace>

@{
    ViewData["Title"] = "Sport Spaces";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-futbol me-2 text-success"></i>Sport Spaces</h4>
        <small class="text-muted">Sport Spaces Management</small>
    </div>
    <a asp-action="Create" asp-controller="SportSpace" class="btn btn-success">
        <i class="fas fa-plus me-2"></i>New Sport Space
    </a>
</div>

@if (TempData["message"] != null)
{
    string success = TempData["success"]?.ToString() ?? "True";
    string alertClass = success == "True" ? "alert-success" : "alert-danger";
    string icon = success == "True" ? "fa-circle-check" : "fa-circle-xmark";
    <div class="alert @alertClass alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="fas @icon me-2"></i>@TempData["message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <form method="get" asp-action="Index" asp-controller="SportSpace" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label mb-1 small fw-semibold">Filter by type</label>
                <select name="type" class="form-select form-select-sm">
                    <option value="">All types</option>
                    @if (ViewBag.Types != null)
                    {
                        foreach (var t in (IEnumerable<string>)ViewBag.Types)
                        {
                            <option value="@t">@t</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
                <a asp-action="Index" asp-controller="SportSpace" class="btn btn-outline-secondary btn-sm ms-1">
                    <i class="fas fa-xmark me-1"></i>Clean filters
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>NAME</th>
                        <th>TYPE</th>
                        <th>CAPACITY</th>
                        <th class="text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="fas fa-futbol fa-2x mb-2 d-block"></i>No sport spaces found
                            </td>
                        </tr>
                    }
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@s.Id</td>
                            <td class="fw-semibold">@s.Name</td>
                            <td>
                                <span class="badge bg-success-subtle text-success border border-success-subtle">@s.Type</span>
                            </td>
                            <td class="text-muted">
                                <i class="fas fa-users me-1 text-muted"></i>@s.Capacity people
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Show" asp-controller="SportSpace" asp-route-id="@s.Id"
                                   class="btn btn-sm btn-outline-info me-1" title="See details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-controller="SportSpace" asp-route-id="@s.Id"
                                   class="btn btn-sm btn-outline-warning me-1" title="Edit">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form asp-action="Destroy" asp-controller="SportSpace" method="post" class="d-inline">
                                    <input type="hidden" name="Id" value="@s.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                            onclick="return confirm('Are you sure you want to delete this sport space?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>