@model SportComplex.Models.Reservation

@{
    ViewData["Title"] = "Booking Details";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-secondary btn-sm me-3">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-calendar-check me-2 text-info"></i>Booking Details</h4>
        <small class="text-muted">Booking Information</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-5 fw-semibold text-muted">ID</dt>
                    <dd class="col-sm-7">#@Model.Id</dd>

                    <dt class="col-sm-5 fw-semibold text-muted">User</dt>
                    <dd class="col-sm-7">@Model.User?.Name</dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Document</dt>
                    <dd class="col-sm-7">@Model.User?.Document</dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Sport Complex</dt>
                    <dd class="col-sm-7">@Model.SportSpace?.Name</dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Type</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-success-subtle text-success border border-success-subtle">@Model.SportSpace?.Type</span>
                    </dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Date</dt>
                    <dd class="col-sm-7">@Model.Date.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Schedule</dt>
                    <dd class="col-sm-7">
                        @Model.StartTime.ToString(@"hh\:mm") — @Model.EndTime.ToString(@"hh\:mm")
                    </dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Status</dt>
                    <dd class="col-sm-7">
                        @if (Model.Status == "Active")
                        {
                            <span class="badge bg-success">@Model.Status</span>
                        }
                        else if (Model.Status == "Cancelled")
                        {
                            <span class="badge bg-danger">@Model.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.Status</span>
                        }
                    </dd>

                    <dt class="col-sm-5 fw-semibold text-muted">Created At</dt>
                    <dd class="col-sm-7">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-controller="Reservation" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="fas fa-pen me-2"></i>Edit
                </a>
                @if (Model.Status == "Activa")
                {
                    <form asp-action="Cancel" asp-controller="Reservation" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Do you confirm the Booking Cancellation?')">
                            <i class="fas fa-ban me-2"></i>Cancel Booking
                        </button>
                    </form>
                }
                <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-secondary btn-sm">Go Back</a>
            </div>
        </div>
    </div>
</div>