@model SportComplex.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="User" class="btn btn-outline-secondary btn-sm me-3">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-pen me-2 text-warning"></i>Edit User</h4>
        <small class="text-muted">Update User Info</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Update" asp-controller="User" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mt-3">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input type="text" class="form-control" asp-for="Name" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold">ID Number</label>
                        <input type="text" class="form-control" asp-for="Document" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold">Phone Number</label>
                        <input type="text" class="form-control" asp-for="Phone" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" class="form-control" asp-for="Email" />
                    </div>

                    @if (TempData["message"] != null && TempData["success"]?.ToString() != "True")
                    {
                        <div class="alert alert-danger rounded-3 mt-3">
                            <i class="fas fa-circle-xmark me-2"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-warning">
                            <i class="fas fa-floppy-disk me-2"></i>Update
                        </button>
                        <a asp-action="Index" asp-controller="User" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>